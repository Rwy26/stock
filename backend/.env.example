# Copy to backend/.env and fill values
# Or run scripts/setup-mysql-service.ps1 with -WriteBackendEnv

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=apollo_db
MYSQL_USER=apollo
MYSQL_PASSWORD=change_me

# JWT (required for real production; defaults are dev-only)
JWT_SECRET=dev-secret-change-me-please-change-me-32bytes
JWT_EXPIRE_MINUTES=1200

# KIS OpenAPI (optional; profile stores app key/secret, these configure base URLs)
KIS_LIVE_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443

# If 1, price endpoints error when KIS fails (no DB fallback)
KIS_STRICT_PRICE=0

# Auto-trading engine safety kill switch (1 = disable all engine ticks/orders)
AUTOTRADING_KILL_SWITCH=0

# Safety gate for real (live) order placement (paper trading is unaffected)
AUTOTRADING_LIVE_ORDERS=0
# Optional: use a full SQLAlchemy URL instead of the fields above
# MYSQL_URL=mysql+pymysql://apollo:change_me@127.0.0.1:3306/apollo_db?charset=utf8mb4
