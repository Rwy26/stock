# Copy to backend/.env and fill values
# Or run scripts/setup-mysql-service.ps1 with -WriteBackendEnv

# Seed admin login (used by backend/db_init.py when creating/upgrading the default admin user id=1)
# If ADMIN_PASSWORD is omitted, db_init will generate a strong password and print it once to the console.
ADMIN_EMAIL=administrator
ADMIN_PASSWORD=ChangeMe!

# If 1, db_init will overwrite the existing id=1 admin password hash with ADMIN_PASSWORD.
# Safer default is 0 (do not overwrite real passwords).
ADMIN_PASSWORD_FORCE=0

# Optional: non-interactive admin automation (used by scripts/admin-create-user-and-kis-profile.ps1)
# User to create/update
SEED_USER_EMAIL=user1@example.com
SEED_USER_PASSWORD=UserPass123!
SEED_USER_NICKNAME=user1
SEED_USER_ROLE=user
SEED_USER_IS_ACTIVE=1

# KIS profile to save for that user (stored in DB; secret is never returned by GET APIs)
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_ACCOUNT_PREFIX=12345678
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_TRADE_TYPE=실계좌

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=apollo_db
MYSQL_USER=apollo
MYSQL_PASSWORD=change_me

# JWT (required for real production; defaults are dev-only)
JWT_SECRET=dev-secret-change-me-please-change-me-32bytes
JWT_EXPIRE_MINUTES=1200

# KIS OpenAPI (optional; profile stores app key/secret, these configure base URLs)
KIS_LIVE_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443

# If 1, price endpoints error when KIS fails (no DB fallback)
KIS_STRICT_PRICE=0

# Auto-trading engine safety kill switch (1 = disable all engine ticks/orders)
AUTOTRADING_KILL_SWITCH=0

# Safety gate for real (live) order placement (paper trading is unaffected)
AUTOTRADING_LIVE_ORDERS=0
# Optional: use a full SQLAlchemy URL instead of the fields above
# MYSQL_URL=mysql+pymysql://apollo:change_me@127.0.0.1:3306/apollo_db?charset=utf8mb4
